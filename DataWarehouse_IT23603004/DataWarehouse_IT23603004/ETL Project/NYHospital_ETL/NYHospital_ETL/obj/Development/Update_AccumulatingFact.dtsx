        <SQLTask:SqlTaskData
          SQLTask:Connection="{D0B0EAEB-DE67-4ED4-AD60-03B664AA9459}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET&#xA;    f.accm_txn_complete_time = TRY_CAST(c.accm_txn_complete_time AS DATETIME),&#xA;    f.txn_process_time_hours = ABS(DATEDIFF(MINUTE,&#xA;        f.accm_txn_create_time,&#xA;        TRY_CAST(c.accm_txn_complete_time AS DATETIME)) / 60.0)&#xA;FROM dbo.FactAdmission f&#xA;JOIN dbo.StagingCompletions c&#xA;    ON f.txn_id = TRY_CAST(c.txn_id AS INT)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
