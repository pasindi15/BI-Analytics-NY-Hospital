  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load FactAdmission"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{C0CD0EF4-C1F1-4716-8343-3543167056C0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactAdmission"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{82ADBC94-D161-4E05-BC9F-C234A61BED4F}"
          SQLTask:SqlStatementSource="INSERT INTO NYHospitalDW.dbo.FactAdmission (&#xA;    hospital_key, patient_key, date_key, diagnosis_key,&#xA;    procedure_key, payment_key, txn_id, type_of_admission,&#xA;    patient_disposition, emergency_dept_indicator,&#xA;    abortion_edit_indicator, birth_weight,&#xA;    length_of_stay, total_charges, total_costs,&#xA;    accm_txn_create_time&#xA;)&#xA;SELECT&#xA;    h.hospital_key,&#xA;    p.patient_key,&#xA;    d.date_key,&#xA;    diag.diagnosis_key,&#xA;    pr.procedure_key,&#xA;    pay.payment_key,&#xA;    s.txn_id,&#xA;    s.type_of_admission,&#xA;    s.patient_disposition,&#xA;    s.emergency_dept_indicator,&#xA;    s.abortion_edit_indicator,&#xA;    TRY_CAST(s.birth_weight AS INT),&#xA;    TRY_CAST(s.length_of_stay AS INT),&#xA;    TRY_CAST(s.total_charges AS DECIMAL(12,2)),&#xA;    TRY_CAST(s.total_costs AS DECIMAL(12,2)),&#xA;    GETDATE()&#xA;FROM NYHospitalOLTP.dbo.StagingAdmissions s&#xA;JOIN NYHospitalDW.dbo.DimHospital h &#xA;    ON CAST(s.facility_id AS INT) = h.facility_id AND h.is_current = 1&#xA;JOIN NYHospitalDW.dbo.DimPatient p &#xA;    ON s.age_group = p.age_group AND s.gender = p.gender &#xA;    AND s.race = p.race AND s.ethnicity = p.ethnicity&#xA;JOIN NYHospitalDW.dbo.DimDate d &#xA;    ON CAST(s.discharge_year AS INT) * 100 + 1 = d.date_key&#xA;JOIN NYHospitalDW.dbo.DimDiagnosis diag &#xA;    ON s.ccs_diagnosis_code = diag.ccs_diagnosis_code&#xA;JOIN NYHospitalDW.dbo.DimProcedure pr &#xA;    ON s.ccs_procedure_code = pr.ccs_procedure_code&#xA;JOIN NYHospitalDW.dbo.DimPayment pay &#xA;    ON s.source_of_payment_1 = pay.source_of_payment_1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
